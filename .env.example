# ============================================================
# SailTracker — Configuration (.env.example)
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# ── AIS Stream (https://aisstream.io) ──────────────────────
# Clé API pour le tracking AIS en temps réel
AISSTREAM_API_KEY=your_aisstream_api_key_here

# ── Bateau ─────────────────────────────────────────────────
# MMSI du voilier (9 chiffres)
VESSEL_MMSI=123456789
# Nom affiché dans le dashboard
VESSEL_NAME=Mon Voilier

# ── Garmin InReach MapShare ────────────────────────────────
# URL KML MapShare de votre device (Settings > MapShare > KML Feed)
INREACH_KML_URL=https://share.garmin.com/Feed/Share/YourFeedID
# Intervalle de polling en secondes (défaut: 600 = 10 min)
INREACH_POLL_INTERVAL=600

# ── Copernicus Marine Service ──────────────────────────────
# Compte sur https://marine.copernicus.eu (gratuit)
COPERNICUS_USER=your_copernicus_username
COPERNICUS_PASS=your_copernicus_password

# ── Telegram Bot (alertes) ─────────────────────────────────
# Créer un bot via @BotFather, obtenir token + chat_id
TELEGRAM_BOT_TOKEN=1234567890:AAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TELEGRAM_CHAT_ID=987654321

# ── Serveur Flask ──────────────────────────────────────────
FLASK_HOST=127.0.0.1
FLASK_PORT=8085
# URL publique du serveur (pour les liens dans les messages Telegram)
SERVER_URL=http://your-server-ip:8085
